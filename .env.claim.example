# Runner separado de claim (proxy/relayer)

# Chave privada da wallet owner (MetaMask) conectada na Polymarket
POLY_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Para conta proxy/safe
POLY_SIGNATURE_TYPE=2
POLY_FUNDER=0xYOUR_PROXY_OR_FUNDER_ADDRESS

# RPC Polygon
POLY_RPC_URL=https://polygon-rpc.com

# Relayer
POLYMARKET_RELAYER_URL=https://relayer-v2.polymarket.com

# Builder credentials
POLY_BUILDER_API_KEY=
POLY_BUILDER_SECRET=
POLY_BUILDER_PASSPHRASE=
